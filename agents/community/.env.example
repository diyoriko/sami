# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNO...   # от @BotFather
TELEGRAM_CHANNEL_ID=@sami_daily                   # username канала или -100...
TELEGRAM_GROUP_ID=@sami_chat                      # username группы или -100...
TELEGRAM_ADMIN_USER_ID=123456789                  # твой Telegram user ID (узнать: @userinfobot)

# YouTube
YOUTUBE_API_KEY=AIzaSy...                         # Google Cloud → YouTube Data API v3

# Paths (относительно папки agents/community/)
COMMUNITY_DB_PATH=./data/community.sqlite
STRATEGIST_LATEST_JSON=../../reports/strategist/.internal/latest.json
COMMUNITY_REPORT_DIR=../../reports/community/.internal

# Schedule (cron, Moscow time by default)
# CRON_SEARCH_VIDEOS=0 19 * * *      # 19:00 — поиск и апрув
# CRON_POST_STRETCHING=0 8 * * *     # 08:00 — стретчинг
# CRON_POST_STRENGTH=0 12 * * *      # 12:00 — силовая
# CRON_POST_MOBILITY=0 17 * * *      # 17:00 — мобильность
# CRON_CHECKIN=0 21 * * *            # 21:00 — чекин
